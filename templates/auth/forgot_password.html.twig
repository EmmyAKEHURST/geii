{% extends 'layouts/auth.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block auth_title %}Mot de passe oublié{% endblock %}

{% block content %}
    <form method="post" class="auth-form">
        <div class="mb-4">
            <label class="form-label" for="email">Email</label>
            <input class="form-control"
                   type="email"
                   id="email"
                   name="email"
                   autocomplete="email"
                   placeholder="Email"
                   required>
        </div>
        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('forgot_password') }}">

        <button class="btn btn-warning btn-lg fw-semibold w-100 auth-submit" type="submit">
            Envoyer le lien de réinitialisation
        </button>
    </form>
{% endblock %}

{% block auth_footer_links %}
    <a class="auth-secondary-link" href="{{ path('app_login') }}">Retour à la connexion</a>
{% endblock %}
