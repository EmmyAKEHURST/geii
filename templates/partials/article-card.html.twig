{# Article card component — Paramètres: date, title, excerpt, link, linkLabel #}
<div class="col-lg-4 col-md-6">
    <article class="card card-article h-100">
        <div class="card-body d-flex flex-column">
            <span class="badge-geii badge mb-3 align-self-start px-3 py-2">
                {{ date }}
            </span>
            <h5 class="card-title-geii fw-semibold mb-2">
                {{ title }}
            </h5>
            <p class="card-text-geii flex-grow-1">
                {{ excerpt }}
            </p>
            <a href="{{ link }}"
               class="link-yellow mt-3 fw-semibold"
               aria-label="{{ linkLabel }}">
                Lire la suite →
            </a>
        </div>
    </article>
</div>
