<!DOCTYPE html>
<html lang="fr" {% if app.environment == 'dev' %} data-turbo="false"{% endif %}>
    <head>
        <title>{% block title %}GEII — IUT{% endblock %}</title>

        {% include 'partials/head-meta.html.twig' %}

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="auth-page bg-section-light">
        <main class="auth-shell">
            <section class="auth-visual hero-section" style="--hero-bg: url('{{ asset('images/hero-bg.jpg') }}')" aria-label="Univers GEII">
                <div class="hero-overlay auth-visual-overlay" aria-hidden="true"></div>
                <div class="auth-visual-content">
                    {% block auth_visual %}
                        <span class="badge-geii badge rounded-pill px-3 py-2 mb-4">
                            IUT &middot; Département GEII
                        </span>
                        <h2 class="hero-title text-white fw-bold mb-3">
                            Bienvenue dans l'espace GEII
                        </h2>
                        <p class="hero-subtitle mb-0">
                            Connectez-vous pour accéder à vos informations personnelles et aux services du département.
                        </p>
                    {% endblock %}
                </div>
            </section>
            <section class="auth-panel">
                <div class="auth-panel-content">
                    <h1 class="auth-title section-title">{% block auth_title %}{% endblock %}</h1>
                    {% block content %}{% endblock %}
                </div>
                <footer class="auth-panel-footer">
                    {% block auth_footer_links %}{% endblock %}
                    <span class="auth-copyright mb-0">GEII - 2026</span>
                </footer>
            </section>
        </main>

        {% block scripts_footer %}{% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    </body>
</html>
