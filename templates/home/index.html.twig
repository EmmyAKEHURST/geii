{% extends 'layouts/base.html.twig' %}

{% block title %}Accueil — Département GEII{% endblock %}

{# Barre de navigation (#1a1a1a, (navbar-geii), responsive #}
{% block navbar %}
    {% include 'partials/navbar-geii.html.twig' %}
{% endblock %}

{% block content %}
    <section class="hero-section" style="--hero-bg: url('{{ asset('images/hero-bg.jpg') }}')" aria-label="Bannière principale">
        {# Overlay semi-transparent #}
        <div class="hero-overlay" aria-hidden="true"></div>

        {# Contenu centré #}
        <div class="container hero-content text-center py-5">
            <span class="badge-geii badge rounded-pill mb-4 px-3 py-2">
                IUT &middot; Département officiel
            </span>

            <h1 class="hero-title text-white mb-3 fw-bold">
                Génie Électrique et Informatique Industrielle
            </h1>

            <p class="hero-subtitle mb-5 mx-auto">
                Former les ingénieurs de demain &middot; Alternance &middot; Licences Pro &middot; Innovation
            </p>

            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a href="{{ path('app_presentation') }}"
                   class="btn btn-warning btn-lg fw-semibold"
                   aria-label="Découvrir le DUT GEII — en savoir plus sur la formation">
                    <i class="bi bi-lightning-charge-fill me-2" aria-hidden="true"></i>
                    Découvrir le DUT GEII
                </a>
                <a href="{{ path('app_espace_etudiant') }}"
                   class="btn btn-outline-light btn-lg fw-semibold"
                   aria-label="Accéder à l'espace étudiant">
                    <i class="bi bi-mortarboard me-2" aria-hidden="true"></i>
                    Espace Étudiant
                </a>
            </div>
        </div>

        {# Indicateur de défilement (chevron pulsant) #}
        <a href="#section-chiffres"
           class="scroll-indicator text-white text-decoration-none"
           aria-label="Défiler vers le contenu principal">
            <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" fill="currentColor"
                 viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd"
                      d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
            </svg>
        </a>
    </section>

    {# Les chiffres clés #}
    <section id="section-chiffres" class="py-5 bg-white" aria-labelledby="titre-chiffres">
        <div class="container">
            <h2 class="section-title text-center mb-5" id="titre-chiffres">
                Le département en chiffres
            </h2>

            <div class="row g-4 justify-content-center">
                <div class="col-lg-3 col-md-6">
                    <div class="card card-stat h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-mortarboard icon-stat d-block mb-3"
                               aria-hidden="true"></i>
                            <div class="stat-number">250+</div>
                            <div class="stat-label mt-2">Étudiants formés chaque année</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card card-stat h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-buildings icon-stat d-block mb-3"
                               aria-hidden="true"></i>
                            <div class="stat-number">120+</div>
                            <div class="stat-label mt-2">Entreprises partenaires</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card card-stat h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-award icon-stat d-block mb-3"
                               aria-hidden="true"></i>
                            <div class="stat-number">3</div>
                            <div class="stat-label mt-2">Licences Professionnelles</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card card-stat h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-arrow-repeat icon-stat d-block mb-3"
                               aria-hidden="true"></i>
                            <div class="stat-number">40%</div>
                            <div class="stat-label mt-2">Étudiants en alternance</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    {# Nos formations #}
    <section class="py-5 bg-section-light" aria-labelledby="titre-formations">
        <div class="container">
            <h2 class="section-title text-center mb-3" id="titre-formations">
                Nos formations
            </h2>
            <p class="section-lead text-center mb-5">
                Du DUT aux Licences Professionnelles, des parcours adaptés à chaque projet
            </p>
            <div class="row g-4">
                {% include 'partials/card-item.html.twig' with {
                    icon: 'bi-lightning-charge',
                    title: 'DUT GEII',
                    badge: 'Bac+2',
                    description: 'Le socle technique en électronique, automatisme et informatique industrielle.',
                    link: path('app_presentation'),
                    linkLabel: 'En savoir plus sur le DUT GEII'
                } %}
                {% include 'partials/card-item.html.twig' with {
                    icon: 'bi-code-slash',
                    title: 'LP MIAW',
                    badge: 'Bac+3',
                    description: 'Métiers de l\'Informatique — Applications Web et Mobiles.',
                    link: path('app_lp_miaw'),
                    linkLabel: 'En savoir plus sur la LP MIAW'
                } %}
                {% include 'partials/card-item.html.twig' with {
                    icon: 'bi-database',
                    title: 'LP ABDD',
                    badge: 'Bac+3',
                    description: 'Automatisme, Bases de Données et Développement.',
                    link: path('app_lp_abdd'),
                    linkLabel: 'En savoir plus sur la LP ABDD'
                } %}
                {% include 'partials/card-item.html.twig' with {
                    icon: 'bi-thermometer-half',
                    title: 'LP GTHBT',
                    badge: 'Bac+3',
                    description: 'Génie Thermique, Hydraulique, Bâtiment et Travaux.',
                    link: path('app_lp_gthbt'),
                    linkLabel: 'En savoir plus sur la LP GTHBT'
                } %}
            </div>
        </div>
    </section>

    {# Espaces personnels #}
    <section class="py-5 bg-white" aria-labelledby="titre-espaces">
        <div class="container">
            <h2 class="section-title text-center mb-5" id="titre-espaces">
                Vos espaces personnels
            </h2>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="espace-card espace-etudiant h-100">
                        <i class="bi bi-mortarboard icon-espace d-block mb-3"
                           aria-hidden="true"></i>
                        <h3 class="fw-bold text-white mb-3">Espace Étudiant</h3>
                        <ul class="mb-4">
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Consulter mes notes
                            </li>
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Mon emploi du temps
                            </li>
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Supports de cours
                            </li>
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Offres d'alternance
                            </li>
                        </ul>
                        <a href="{{ path('app_espace_etudiant') }}"
                           class="btn btn-warning fw-semibold"
                           aria-label="Accéder à l'espace étudiant">
                            Accéder à mon espace →
                        </a>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="espace-card espace-enseignant h-100">
                        <i class="bi bi-person-video3 icon-espace d-block mb-3"
                           aria-hidden="true"></i>
                        <h3 class="fw-bold text-white mb-3">Espace Enseignant</h3>
                        <ul class="mb-4">
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Déposer mes supports
                            </li>
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Gérer les notes
                            </li>
                            <li>
                                <i class="bi bi-check-circle me-2 icon-geii" aria-hidden="true"></i>
                                Mon emploi du temps
                            </li>
                        </ul>
                        <a href="{{ path('app_espace_enseignant') }}"
                           class="btn btn-warning fw-semibold"
                           aria-label="Accéder à l'espace enseignant">
                            Accéder à mon espace →
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Alternance / Partenaires entreprises #}
    <section class="py-5 bg-section-light" aria-labelledby="titre-alternance">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h2 class="section-title text-start mb-4" id="titre-alternance">
                        Vous êtes une entreprise&nbsp;?
                    </h2>
                    <p class="text-body-geii lh-relaxed mb-4">
                        Le département GEII vous propose des étudiants qualifiés en alternance et des
                        projets tuteurés pour répondre à vos besoins techniques. Rejoignez un réseau de
                        plus de <strong class="text-geii-black">120 partenaires industriels</strong> et
                        contribuez à la formation des ingénieurs de demain.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="{{ path('app_alternance_offre') }}"
                           class="btn btn-warning fw-semibold"
                           aria-label="Proposer une offre d'alternance au département GEII">
                            <i class="bi bi-briefcase me-2" aria-hidden="true"></i>Proposer une offre d'alternance
                        </a>
                        <a href="{{ path('app_projet_tuteure') }}"
                           class="btn btn-outline-dark fw-semibold"
                           aria-label="Déposer un projet tuteuré au département GEII">
                            <i class="bi bi-diagram-3 me-2" aria-hidden="true"></i>Déposer un projet tuteuré
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="d-flex flex-column gap-3">
                        <div class="mini-card d-flex align-items-start gap-3">
                            <i class="bi bi-people-fill icon-mini-card flex-shrink-0"
                               aria-hidden="true"></i>
                            <div>
                                <h5 class="mini-card-title fw-semibold mb-1">
                                    Partenariat sur mesure
                                </h5>
                                <p class="mini-card-text mb-0 small">
                                    Un interlocuteur pédagogique dédié pour adapter chaque mission à vos besoins métier.
                                </p>
                            </div>
                        </div>
                        <div class="mini-card d-flex align-items-start gap-3">
                            <i class="bi bi-calendar-check icon-mini-card flex-shrink-0"
                               aria-hidden="true"></i>
                            <div>
                                <h5 class="mini-card-title fw-semibold mb-1">
                                    Planning flexible
                                </h5>
                                <p class="mini-card-text mb-0 small">
                                    Des rythmes d'alternance adaptés à votre organisation et à votre secteur d'activité.
                                </p>
                            </div>
                        </div>
                        <div class="mini-card d-flex align-items-start gap-3">
                            <i class="bi bi-graph-up icon-mini-card flex-shrink-0"
                               aria-hidden="true"></i>
                            <div>
                                <h5 class="mini-card-title fw-semibold mb-1">
                                    Compétences opérationnelles
                                </h5>
                                <p class="mini-card-text mb-0 small">
                                    Des étudiants formés aux outils et aux méthodes de l'industrie dès la première
                                    année.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {#
        ACTUALITÉS
        TODO: remplacer par des articles issus de la base de données
    #}
    <section class="py-5 bg-white" aria-labelledby="titre-actualites">
        <div class="container">
            <h2 class="section-title text-center mb-5" id="titre-actualites">
                Actualités du département
            </h2>
            <div class="row g-4">
                {% include 'partials/article-card.html.twig' with {
                    date: '15 mars 2026',
                    title: 'Journée portes ouvertes 2026',
                    excerpt: 'Venez découvrir nos laboratoires, rencontrer l\'équipe pédagogique et échanger avec des étudiants lors de notre journée portes ouvertes annuelle.',
                    link: '#',
                    linkLabel: 'Lire la suite de l\'article : Journée portes ouvertes 2026'
                } %}

                {% include 'partials/article-card.html.twig' with {
                    date: '02 février 2026',
                    title: 'Nouveaux partenariats industriels',
                    excerpt: 'Cinq nouvelles entreprises rejoignent le réseau partenaires GEII pour proposer des offres d\'alternance et des projets tuteurés dès la rentrée 2026.',
                    link: '#',
                    linkLabel: 'Lire la suite de l\'article : Nouveaux partenariats industriels'
                } %}

                {% include 'partials/article-card.html.twig' with {
                    date: '20 janvier 2026',
                    title: 'Résultats du hackathon GEII',
                    excerpt: 'Retour sur le hackathon annuel : les étudiants ont relevé des défis d\'automatisme et d\'IoT en 24 heures. Découvrez les projets primés.',
                    link: '#',
                    linkLabel: 'Lire la suite de l\'article : Résultats du hackathon GEII'
                } %}
            </div>
        </div>
    </section>
{% endblock %}
