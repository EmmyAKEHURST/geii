               aria-label="Accéder à l'espace étudiant">
                <i class="bi bi-mortarboard me-2" aria-hidden="true"></i>Espace Étudiant
            </a>
        </div>

    </div>

    {# Indicateur de défilement (chevron pulsant) #}
